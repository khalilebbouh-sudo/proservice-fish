NODE_ENV=development
PORT=5000
# Mongo réel (Docker / install / Atlas). Ignoré si USE_MEMORY_MONGO=1 en développement.
MONGODB_URI=mongodb://127.0.0.1:27017/proservice_fish
# Dev sans Mongo installé : décommentez la ligne suivante et lancez npm run dev:memory
# USE_MEMORY_MONGO=1
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=1d
# Dev: http://localhost:3000 — Production: https://votre-domaine.com (obligatoire https pour CORS + cookies)
FRONTEND_URL=http://localhost:3000
ADMIN_EMAIL=admin@proservicefish.local
ADMIN_PASSWORD=ChangeMeOnFirstRun!123
